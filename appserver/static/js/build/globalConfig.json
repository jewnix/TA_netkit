{
    "meta": {
        "name": "TA_netkit",
        "displayName": "NetKit Add-on",
        "version": "1.0.0",
        "restRoot": "TA_netkit",
        "schemaVersion": "0.0.10",
        "supportedPythonVersion": [
            "3.13"
        ],
        "_uccVersion": "6.5.2"
    },
    "pages": {
        "configuration": {
            "title": "Configuration",
            "description": "Configure NetKit logging.",
            "tabs": [
                {
                    "name": "logging",
                    "title": "Logging",
                    "entity": [
                        {
                            "field": "loglevel",
                            "label": "Log level",
                            "type": "singleSelect",
                            "defaultValue": "INFO",
                            "validators": [
                                {
                                    "type": "regex",
                                    "pattern": "^(DEBUG|INFO|WARNING|ERROR)$",
                                    "errorMsg": "Log level must be one of DEBUG, INFO, WARNING, ERROR."
                                }
                            ],
                            "options": {
                                "disableSearch": true,
                                "autoCompleteFields": [
                                    {
                                        "value": "DEBUG",
                                        "label": "DEBUG"
                                    },
                                    {
                                        "value": "INFO",
                                        "label": "INFO"
                                    },
                                    {
                                        "value": "WARNING",
                                        "label": "WARNING"
                                    },
                                    {
                                        "value": "ERROR",
                                        "label": "ERROR"
                                    }
                                ]
                            },
                            "required": true
                        }
                    ]
                }
            ]
        },
        "inputs": {
            "title": "Inputs",
            "description": "Manage NetKit probe inputs.",
            "table": {
                "header": [
                    {
                        "field": "name",
                        "label": "Name"
                    },
                    {
                        "field": "interval",
                        "label": "Interval"
                    },
                    {
                        "field": "index",
                        "label": "Index"
                    },
                    {
                        "field": "disabled",
                        "label": "Status"
                    }
                ],
                "actions": [
                    "edit",
                    "delete",
                    "clone"
                ]
            },
            "services": [
                {
                    "name": "ping_probe",
                    "title": "Ping (TCP-connect latency)",
                    "inputHelperModule": "netkit_ping",
                    "entity": [
                        {
                            "field": "name",
                            "label": "Name",
                            "type": "text",
                            "required": true,
                            "validators": [
                                {
                                    "type": "regex",
                                    "pattern": "^[a-zA-Z]\\w*$",
                                    "errorMsg": "Name must start with a letter and contain only letters, numbers, and underscores."
                                }
                            ]
                        },
                        {
                            "field": "targets",
                            "label": "Targets (comma-separated host:port)",
                            "help": "Hostname, IPv4, or IPv6 host:port, comma-separated. IPv6 literals go without brackets; the last colon separates the port. e.g. 1.1.1.1:443,example.com:8089,2606:4700:4700::1111:443",
                            "type": "text",
                            "required": true,
                            "validators": [
                                {
                                    "type": "regex",
                                    "pattern": "^[ \\t]*[A-Za-z0-9._:-]+:\\d{1,5}([ \\t]*,[ \\t]*[A-Za-z0-9._:-]+:\\d{1,5})*[ \\t]*$",
                                    "errorMsg": "Targets must be a comma-separated list of host:port. Host may be a hostname, IPv4, or IPv6 literal (no brackets), e.g. 1.1.1.1:443,2606:4700:4700::1111:443."
                                }
                            ]
                        },
                        {
                            "field": "count",
                            "label": "Samples per target",
                            "type": "text",
                            "required": false,
                            "defaultValue": "4",
                            "validators": [
                                {
                                    "type": "number",
                                    "range": [
                                        1,
                                        100
                                    ],
                                    "isInteger": true
                                }
                            ]
                        },
                        {
                            "field": "timeout_ms",
                            "label": "Connect timeout (ms)",
                            "type": "text",
                            "required": false,
                            "defaultValue": "2000",
                            "validators": [
                                {
                                    "type": "number",
                                    "range": [
                                        1,
                                        60000
                                    ],
                                    "isInteger": true
                                }
                            ]
                        },
                        {
                            "field": "interval",
                            "label": "Interval (seconds)",
                            "type": "text",
                            "required": true,
                            "defaultValue": "60",
                            "validators": [
                                {
                                    "type": "number",
                                    "range": [
                                        10,
                                        86400
                                    ],
                                    "isInteger": true
                                }
                            ]
                        },
                        {
                            "type": "singleSelect",
                            "field": "index",
                            "label": "Index",
                            "defaultValue": "default",
                            "options": {
                                "endpointUrl": "data/indexes?search=isInternal=0+disabled=0",
                                "denyList": "^_.*$",
                                "createSearchChoice": true
                            },
                            "validators": [
                                {
                                    "type": "index_name"
                                }
                            ],
                            "help": "Destination index. Leave unset to route to the admin default; align the netkit_index macro on the search head to match."
                        }
                    ]
                },
                {
                    "name": "speedtest_probe",
                    "title": "Speedtest (Cloudflare throughput)",
                    "inputHelperModule": "netkit_speedtest",
                    "entity": [
                        {
                            "field": "name",
                            "label": "Name",
                            "type": "text",
                            "required": true,
                            "validators": [
                                {
                                    "type": "regex",
                                    "pattern": "^[a-zA-Z]\\w*$",
                                    "errorMsg": "Name must start with a letter and contain only letters, numbers, and underscores."
                                }
                            ]
                        },
                        {
                            "field": "profile",
                            "label": "Bandwidth profile",
                            "help": "Transfer sizes per run. Larger sizes measure fast links more accurately but use more data per run.",
                            "type": "singleSelect",
                            "required": true,
                            "defaultValue": "standard",
                            "validators": [
                                {
                                    "type": "regex",
                                    "pattern": "^(low|standard|high|custom)$",
                                    "errorMsg": "Profile must be one of low, standard, high, custom."
                                }
                            ],
                            "options": {
                                "disableSearch": true,
                                "autoCompleteFields": [
                                    {
                                        "value": "low",
                                        "label": "Low bandwidth (under 50 Mbps): 10 MB down / 2 MB up"
                                    },
                                    {
                                        "value": "standard",
                                        "label": "Standard (50-300 Mbps): 25 MB down / 5 MB up"
                                    },
                                    {
                                        "value": "high",
                                        "label": "High bandwidth (over 300 Mbps): 100 MB down / 20 MB up"
                                    },
                                    {
                                        "value": "custom",
                                        "label": "Custom"
                                    }
                                ]
                            },
                            "modifyFieldsOnValue": [
                                {
                                    "fieldValue": "custom",
                                    "fieldsToModify": [
                                        {
                                            "fieldId": "download_mb",
                                            "display": true
                                        },
                                        {
                                            "fieldId": "upload_mb",
                                            "display": true
                                        }
                                    ]
                                },
                                {
                                    "fieldValue": "[[any_other_value]]",
                                    "fieldsToModify": [
                                        {
                                            "fieldId": "download_mb",
                                            "display": false
                                        },
                                        {
                                            "fieldId": "upload_mb",
                                            "display": false
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "field": "download_mb",
                            "label": "Download size (MB)",
                            "help": "Bytes downloaded per run when the profile is Custom (1-500 MB).",
                            "type": "text",
                            "required": false,
                            "defaultValue": "25",
                            "options": {
                                "display": false,
                                "requiredWhenVisible": true
                            },
                            "validators": [
                                {
                                    "type": "number",
                                    "range": [
                                        1,
                                        500
                                    ],
                                    "isInteger": true
                                }
                            ]
                        },
                        {
                            "field": "upload_mb",
                            "label": "Upload size (MB)",
                            "help": "Bytes uploaded per run when the profile is Custom (1-100 MB).",
                            "type": "text",
                            "required": false,
                            "defaultValue": "5",
                            "options": {
                                "display": false,
                                "requiredWhenVisible": true
                            },
                            "validators": [
                                {
                                    "type": "number",
                                    "range": [
                                        1,
                                        100
                                    ],
                                    "isInteger": true
                                }
                            ]
                        },
                        {
                            "field": "interval",
                            "label": "Interval (seconds)",
                            "help": "Seconds between runs. Minimum 300; the High bandwidth and Custom profiles require at least 900.",
                            "type": "text",
                            "required": true,
                            "defaultValue": "1800",
                            "validators": [
                                {
                                    "type": "number",
                                    "range": [
                                        300,
                                        86400
                                    ],
                                    "isInteger": true
                                }
                            ]
                        },
                        {
                            "type": "singleSelect",
                            "field": "index",
                            "label": "Index",
                            "defaultValue": "default",
                            "options": {
                                "endpointUrl": "data/indexes?search=isInternal=0+disabled=0",
                                "denyList": "^_.*$",
                                "createSearchChoice": true
                            },
                            "validators": [
                                {
                                    "type": "index_name"
                                }
                            ],
                            "help": "Destination index. Leave unset to route to the admin default; align the netkit_index macro on the search head to match."
                        }
                    ]
                }
            ]
        }
    }
}
